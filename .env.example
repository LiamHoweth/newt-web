# Public site URL (used in notification links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard password (MVP auth)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Supabase (optional — falls back to local JSON files in /data when unset)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications via Resend (optional — logs to console when unset)
RESEND_API_KEY=
OWNER_NOTIFICATION_EMAIL=
# Optional: custom from address (must be verified in Resend)
# RESEND_FROM_EMAIL=All4One Quotes <quotes@yourdomain.com>

# SMS notifications via Twilio (optional — skipped when unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_SMS_NUMBER=
