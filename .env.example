# Public site URL (used in admin links, email/SMS notifications)
# Production: https://all4oneexterior.com (match your canonical domain, with or without www)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin dashboard password — required for /admin login
# Set in .env.local (local) and Cloudflare runtime secrets (production)
# Do not commit real passwords to git
ADMIN_PASSWORD=change-me-to-a-strong-password

# Supabase — required for production on Cloudflare (Workers cannot persist ./data JSON)
# Run supabase/schema.sql in your Supabase SQL editor after creating a project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications via Resend (optional — logs to console when unset)
RESEND_API_KEY=
OWNER_NOTIFICATION_EMAIL=
# Optional: custom from address (must be verified in Resend)
# RESEND_FROM_EMAIL=All4One Quotes <quotes@yourdomain.com>

# SMS notifications via Twilio (optional — skipped when unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_SMS_NUMBER=
